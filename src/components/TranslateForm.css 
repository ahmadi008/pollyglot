/* ===== SHARED CARD SHELL ===== */
.card {
  width: 100%;
  max-width: 360px;
  background: #ffffff;
  border: 2px solid #a8c0e8;
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 12px 40px rgba(14, 19, 99, 0.16);
}

/* ===== HEADER (dark navy) ===== */
.card-header {
  background: linear-gradient(140deg, #0e1363 0%, #1a237e 100%);
  padding: 1.2rem 1.4rem;
  position: relative;
  overflow: hidden;
  min-height: 78px;
  display: flex;
  align-items: center;
}

/* Globe decoration (concentric circles in top-right) */
.globe-decor {
  position: absolute;
  right: -22px;
  top: -22px;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  border: 1.5px solid rgba(255, 255, 255, 0.12);
  box-shadow:
    0 0 0 22px rgba(255, 255, 255, 0.04),
    0 0 0 44px rgba(255, 255, 255, 0.025);
}
.globe-decor::before {
  content: '';
  position: absolute;
  inset: 18px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.07);
}

.logo-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  position: relative;
  z-index: 1;
}

.logo-badge {
  width: 46px;
  height: 46px;
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.55rem;
  flex-shrink: 0;
}

.logo-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.logo-tagline {
  font-size: 0.6rem;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 1px;
  letter-spacing: 0.01em;
}

/* ===== FORM BODY ===== */
.card-body {
  padding: 1.4rem;
}

.translate-form {
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.field-label {
  font-size: 0.78rem;
  font-weight: 600;
  color: #2d5be3;
}

/* Textarea */
.text-input {
  width: 100%;
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: 10px;
  color: var(--text-dark);
  font-family: 'Poppins', sans-serif;
  font-size: 0.88rem;
  line-height: 1.5;
  padding: 0.7rem 0.9rem;
  resize: none;
  transition: border-color 0.2s;
}
.text-input:focus {
  outline: none;
  border-color: #2d5be3;
  box-shadow: 0 0 0 3px rgba(45, 91, 227, 0.12);
}
.text-input::placeholder { color: var(--text-muted); }

/* Language radio buttons */
.language-options {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.language-option {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  cursor: pointer;
  font-size: 0.88rem;
  color: var(--text-dark);
  padding: 0.15rem 0;
}
.language-option input[type="radio"] {
  width: 16px;
  height: 16px;
  accent-color: #2d5be3;
  cursor: pointer;
  flex-shrink: 0;
}
.lang-name { flex: 1; }
.lang-flag { font-size: 1.1rem; line-height: 1; }

/* Error message */
.error-msg {
  background: #fff5f5;
  border: 1px solid #fed7d7;
  border-radius: 8px;
  color: #c53030;
  font-size: 0.8rem;
  padding: 0.6rem 0.9rem;
}

/* Translate button */
.translate-btn {
  width: 100%;
  background: var(--blue);
  border: none;
  border-radius: 10px;
  color: #ffffff;
  cursor: pointer;
  font-family: 'Poppins', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  padding: 0.85rem;
  transition: background 0.2s, transform 0.1s;
  letter-spacing: 0.01em;
}
.translate-btn:hover:not(:disabled) { background: var(--blue-hover); }
.translate-btn:active:not(:disabled) { transform: scale(0.99); }
.translate-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.translate-btn.loading { opacity: 0.75; cursor: wait; }